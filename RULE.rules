# OWASP Top 10:2025 custom Suricata detection rules
# Target: Suricata 7.x/8.x, IDS alert mode
# SID range: 9901001-9901066 (local/private use)
#
# IMPORTANT
# - These signatures detect network-observable indicators; they cannot prove or fully detect design,
#   authorization, supply-chain, logging, or business-logic failures without application context.
# - HTTPS application payload is invisible unless Suricata receives plaintext traffic at/after TLS termination.
# - Rules tagged confidence Low are behavioral heuristics and must be tuned to the protected application.
# - Set HOME_NET/EXTERNAL_NET correctly and test with: suricata -T -c /etc/suricata/suricata.yaml -S <this-file>

# =============================================================================
# A01:2025 - Broken Access Control
# =============================================================================
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A01:2025 Directory traversal encoded or raw"; flow:established,to_server; http.uri.raw; content:"."; pcre:"/(?:\.\.(?:\/|\\\\)|%2e%2e(?:%2f|%5c)|%2e\.(?:%2f|%5c)|\.%2e(?:%2f|%5c)|%252e%252e(?:%252f|%255c)|%c0%ae%c0%ae)/i"; classtype:web-application-attack; metadata:owasp_top_10 A01_2025, confidence High; sid:9901001; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A01:2025 Sensitive operating system file access"; flow:established,to_server; http.uri; pcre:"/(?:\/etc\/(?:passwd|shadow|hosts)|\/proc\/(?:self|[0-9]+)\/(?:environ|cmdline)|[a-z]:[\/\\\\]windows[\/\\\\](?:win\.ini|system32))/i"; classtype:web-application-attack; metadata:owasp_top_10 A01_2025, confidence High; sid:9901002; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A01:2025 Forced browsing of privileged endpoint"; flow:established,to_server; http.uri; pcre:"/\/(?:admin(?:istrator)?|manage(?:ment)?|internal|private|console|superuser)(?:\/|[?]|$)/i"; detection_filter:track by_src,count 5,seconds 60; classtype:attempted-admin; metadata:owasp_top_10 A01_2025, confidence Medium; sid:9901003; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A01:2025 Possible IDOR object enumeration"; flow:established,to_server; http.uri; pcre:"/\/(?:api\/)?(?:users?|accounts?|orders?|invoices?|documents?|records?|files?)\/[0-9]{1,18}(?:\/|[?]|$)/i"; detection_filter:track by_src,count 10,seconds 30; classtype:web-application-attack; metadata:owasp_top_10 A01_2025, confidence Low; sid:9901004; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A01:2025 Privileged endpoint method tampering"; flow:established,to_server; http.method; pcre:"/^(?:PUT|DELETE|PATCH)$/"; http.uri; pcre:"/\/(?:admin(?:istrator)?|manage(?:ment)?|internal|private|console)(?:\/|[?]|$)/i"; classtype:attempted-admin; metadata:owasp_top_10 A01_2025, confidence Medium; sid:9901005; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A01:2025 SSRF to loopback cloud metadata or private address in URI"; flow:established,to_server; http.uri; pcre:"/(?:^|[?&])(?:url|uri|link|target|dest(?:ination)?|redirect|callback|webhook|image|feed|host)=(?:https?|gopher|file|dict)(?::|%3a)(?:\/\/|%2f%2f)?(?:127(?:\.[0-9]{1,3}){3}|localhost|0\.0\.0\.0|169\.254\.169\.254|\[?::1\]?|metadata\.google\.internal|10(?:\.[0-9]{1,3}){3}|192\.168(?:\.[0-9]{1,3}){2}|172\.(?:1[6-9]|2[0-9]|3[01])(?:\.[0-9]{1,3}){2})/i"; classtype:web-application-attack; metadata:owasp_top_10 A01_2025, confidence High; sid:9901006; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A01:2025 SSRF to loopback cloud metadata or private address in body"; flow:established,to_server; http.request_body; pcre:"/(?:url|uri|link|target|dest(?:ination)?|redirect|callback|webhook|image|feed|host)[\x22']?\s*(?::|=)\s*[\x22']?(?:https?|gopher|file|dict):(?:\/\/)?(?:127(?:\.[0-9]{1,3}){3}|localhost|0\.0\.0\.0|169\.254\.169\.254|\[?::1\]?|metadata\.google\.internal|10(?:\.[0-9]{1,3}){3}|192\.168(?:\.[0-9]{1,3}){2}|172\.(?:1[6-9]|2[0-9]|3[01])(?:\.[0-9]{1,3}){2})/i"; classtype:web-application-attack; metadata:owasp_top_10 A01_2025, confidence High; sid:9901007; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A01:2025 Reverse proxy path override access-control bypass"; flow:established,to_server; http.request_header; pcre:"/(?:^|\r\n)(?:X-Original-URL|X-Rewrite-URL)\s*:\s*\/(?:admin(?:istrator)?|manage(?:ment)?|internal|private|console)(?:\/|[?\r\n])/i"; classtype:attempted-admin; metadata:owasp_top_10 A01_2025, confidence High; sid:9901008; rev:1;)

# =============================================================================
# A02:2025 - Security Misconfiguration
# =============================================================================
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A02:2025 Exposed secret or source-control file request"; flow:established,to_server; http.uri; pcre:"/(?:^|\/)(?:\.env(?:\.[a-z0-9_.-]+)?|\.git\/(?:config|HEAD|index)|\.svn\/entries|\.hg\/hgrc|\.aws\/credentials|\.ssh\/id_rsa|web\.config|application\.properties|config\.(?:php|ya?ml|json))(?:[?\/]|$)/i"; classtype:attempted-recon; metadata:owasp_top_10 A02_2025, confidence High; sid:9901009; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A02:2025 Backup database or configuration artifact request"; flow:established,to_server; http.uri; pcre:"/(?:^|\/)(?:backup|database|db|dump|config|site|www)[^\/?]{0,40}\.(?:bak|old|orig|save|swp|sql|dump|zip|tar|tar\.gz)(?:[?]|$)/i"; classtype:attempted-recon; metadata:owasp_top_10 A02_2025, confidence High; sid:9901010; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A02:2025 Exposed diagnostics or management endpoint"; flow:established,to_server; http.uri; pcre:"/\/(?:actuator\/(?:env|heapdump|configprops|mappings|beans)|server-status|server-info|phpinfo\.php|debug(?:\/|[?]|$)|_profiler|swagger(?:-ui)?(?:\/|[?]|$)|api-docs(?:\/|[?]|$)|jolokia(?:\/|[?]|$))/i"; classtype:attempted-recon; metadata:owasp_top_10 A02_2025, confidence Medium; sid:9901011; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A02:2025 Unsafe HTTP TRACE or TRACK method"; flow:established,to_server; http.method; pcre:"/^(?:TRACE|TRACK)$/"; classtype:policy-violation; metadata:owasp_top_10 A02_2025, confidence High; sid:9901012; rev:1;)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"OWASP A02:2025 Credentialed wildcard CORS response"; flow:established,to_client; http.response_header; pcre:"/^(?=[\s\S]*Access-Control-Allow-Origin\s*:\s*\*)(?=[\s\S]*Access-Control-Allow-Credentials\s*:\s*true)/i"; classtype:policy-violation; metadata:owasp_top_10 A02_2025, confidence High; sid:9901013; rev:1;)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"OWASP A02:2025 Web directory listing exposed"; flow:established,to_client; http.response_body; pcre:"/<title>\s*(?:Index of|Directory listing for)\s+\//i"; classtype:policy-violation; metadata:owasp_top_10 A02_2025, confidence High; sid:9901014; rev:1;)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"OWASP A02:2025 PHP diagnostic page exposed"; flow:established,to_client; http.response_body; content:"phpinfo()"; nocase; pcre:"/(?:PHP Version|PHP Credits|Configuration File \(php\.ini\) Path)/i"; classtype:policy-violation; metadata:owasp_top_10 A02_2025, confidence High; sid:9901015; rev:1;)

# =============================================================================
# A03:2025 - Software Supply Chain Failures
# =============================================================================
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A03:2025 Dependency manifest or lockfile exposure"; flow:established,to_server; http.uri; pcre:"/(?:^|\/)(?:package(?:-lock)?\.json|yarn\.lock|pnpm-lock\.ya?ml|composer\.lock|pom\.xml|build\.gradle|requirements\.txt|Pipfile\.lock|Gemfile\.lock|go\.sum|Cargo\.lock)(?:[?]|$)/i"; classtype:attempted-recon; metadata:owasp_top_10 A03_2025, confidence Medium; sid:9901016; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A03:2025 CI CD or package repository configuration exposure"; flow:established,to_server; http.uri; pcre:"/(?:^|\/)(?:\.github\/workflows\/[^?]+|\.gitlab-ci\.ya?ml|Jenkinsfile|\.circleci\/config\.ya?ml|azure-pipelines\.ya?ml|\.npmrc|\.pypirc|settings\.xml)(?:[?]|$)/i"; classtype:attempted-recon; metadata:owasp_top_10 A03_2025, confidence High; sid:9901017; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A03:2025 Package or build artifact upload to repository endpoint"; flow:established,to_server; http.method; pcre:"/^(?:POST|PUT)$/"; http.uri; pcre:"/\/(?:api\/)?(?:packages?|artifacts?|repositories?|releases?|uploads?)(?:\/|[?]|$)/i"; file.name; pcre:"/\.(?:jar|war|tgz|whl|gem|nupkg|vsix)$/i"; detection_filter:track by_src,count 3,seconds 60; classtype:policy-violation; metadata:owasp_top_10 A03_2025, confidence Low; sid:9901018; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A03:2025 Suspicious package install hook in downloaded manifest"; flow:established,to_client; http.response_body; content:"install"; nocase; pcre:"/[\x22'](?:preinstall|postinstall)[\x22']\s*:\s*[\x22'][^\x22'\r\n]{0,300}(?:curl|wget|powershell|Invoke-WebRequest|certutil|bash\s+-c|sh\s+-c)/i"; classtype:bad-unknown; metadata:owasp_top_10 A03_2025, confidence Medium; sid:9901019; rev:1;)

# =============================================================================
# A04:2025 - Cryptographic Failures
# =============================================================================
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A04:2025 Credential or secret sent in cleartext HTTP body"; flow:established,to_server; http.request_body; pcre:"/(?:password|passwd|pwd|api_?key|access_?token|client_?secret)[\x22']?\s*(?:=|:)\s*[\x22']?[^&\x22'\s]{3,}/i"; classtype:policy-violation; metadata:owasp_top_10 A04_2025, confidence High; sid:9901020; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A04:2025 HTTP Basic authorization sent without TLS"; flow:established,to_server; http.request_header; content:"Authorization|3a| Basic "; nocase; classtype:policy-violation; metadata:owasp_top_10 A04_2025, confidence High; sid:9901021; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A04:2025 Session token or credential in URL"; flow:established,to_server; http.uri; pcre:"/(?:^|[?&])(?:password|passwd|pwd|session(?:id)?|jsessionid|phpsessid|access_?token|api_?key|auth(?:orization)?)=[^&]{4,}/i"; classtype:policy-violation; metadata:owasp_top_10 A04_2025, confidence High; sid:9901022; rev:1;)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"OWASP A04:2025 Session cookie missing Secure attribute"; flow:established,to_client; http.response_header; pcre:"/(?:^|\r\n)Set-Cookie\s*:(?![^\r\n]*\x3b\s*Secure(?:\x3b|\s|\r?$))[^\r\n]+/i"; classtype:policy-violation; metadata:owasp_top_10 A04_2025, confidence Medium; sid:9901023; rev:2;)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"OWASP A04:2025 Session cookie missing HttpOnly attribute"; flow:established,to_client; http.response_header; pcre:"/(?:^|\r\n)Set-Cookie\s*:(?![^\r\n]*\x3b\s*HttpOnly(?:\x3b|\s|\r?$))[^\r\n]+/i"; classtype:policy-violation; metadata:owasp_top_10 A04_2025, confidence Medium; sid:9901024; rev:2;)
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"OWASP A04:2025 Deprecated TLS 1.0 negotiated by protected server"; flow:established,to_client; tls.version:1.0; classtype:policy-violation; metadata:owasp_top_10 A04_2025, confidence High; sid:9901025; rev:1;)
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"OWASP A04:2025 Deprecated TLS 1.1 negotiated by protected server"; flow:established,to_client; tls.version:1.1; classtype:policy-violation; metadata:owasp_top_10 A04_2025, confidence High; sid:9901026; rev:1;)
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"OWASP A04:2025 Expired TLS certificate served"; flow:established,to_client; tls_cert_expired; classtype:policy-violation; metadata:owasp_top_10 A04_2025, confidence High; sid:9901027; rev:1;)

# =============================================================================
# A05:2025 - Injection
# =============================================================================
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A05:2025 SQL injection in URI"; flow:established,to_server; http.uri; pcre:"/(?:\bunion(?:\s|%20|\+)+(?:all(?:\s|%20|\+)+)?select\b|\bselect(?:\s|%20|\+).{0,80}\bfrom\b|(?:'|%27)(?:\s|%20|\+)*(?:or|and)(?:\s|%20|\+)+(?:[0-9]+|'[^']*'|%27[^%]*%27)(?:\s|%20|\+)*(?:=|like)|\b(?:sleep|benchmark|pg_sleep|waitfor(?:\s|%20|\+)+delay)(?:\s|%20|\+)*(?:\(|%28))/i"; classtype:web-application-attack; metadata:owasp_top_10 A05_2025, confidence High; sid:9901028; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A05:2025 SQL injection in request body"; flow:established,to_server; http.request_body; pcre:"/(?:\bunion\s+(?:all\s+)?select\b|\bselect\s+.{0,80}\bfrom\b|'\s*(?:or|and)\s+(?:[0-9]+|'[^']*')\s*(?:=|like)|\b(?:sleep|benchmark|pg_sleep)\s*\(|\bwaitfor\s+delay\b)/i"; classtype:web-application-attack; metadata:owasp_top_10 A05_2025, confidence High; sid:9901029; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A05:2025 Cross-site scripting payload in URI"; flow:established,to_server; http.uri; pcre:"/(?:(?:<|%3c)(?:script|svg|img|iframe|object|body)\b|(?:onerror|onload|onclick|onfocus)(?:\s|%20)*(?:=|%3d)|(?:javascript|vbscript|data)(?::|%3a))/i"; classtype:web-application-attack; metadata:owasp_top_10 A05_2025, confidence High; sid:9901030; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A05:2025 Cross-site scripting payload in request body"; flow:established,to_server; http.request_body; pcre:"/(?:(?:<|&lt\x3b)(?:script|svg|img|iframe|object|body)\b|(?:onerror|onload|onclick|onfocus)\s*=|(?:javascript|vbscript|data)\s*:)/i"; classtype:web-application-attack; metadata:owasp_top_10 A05_2025, confidence High; sid:9901031; rev:2;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A05:2025 Operating system command injection in URI"; flow:established,to_server; http.uri.raw; pcre:"/(?:\x3b|%3b|\||%7c|&&|%26%26|`|%60)(?:\s|%20|\+)*(?:id|whoami|uname|cat|curl|wget|nc|netcat|bash|sh|cmd(?:\.exe)?|powershell|certutil)(?:\b|%20|\+)/i"; classtype:web-application-attack; metadata:owasp_top_10 A05_2025, confidence High; sid:9901032; rev:2;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A05:2025 Operating system command injection in request body"; flow:established,to_server; http.request_body; pcre:"/(?:\x3b|\||&&|`)(?:\s)*(?:id|whoami|uname|cat|curl|wget|nc|netcat|bash|sh|cmd(?:\.exe)?|powershell|certutil)(?:\b|\s)/i"; classtype:web-application-attack; metadata:owasp_top_10 A05_2025, confidence High; sid:9901033; rev:2;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A05:2025 Server-side template injection in URI"; flow:established,to_server; http.uri.raw; pcre:"/(?:\{\{|%7b%7b|\$\{|%24%7b).{0,100}(?:7(?:\*|%2a)7|__class__|__globals__|getRuntime|Runtime|process|config|request|self)/i"; classtype:web-application-attack; metadata:owasp_top_10 A05_2025, confidence High; sid:9901034; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A05:2025 Server-side template injection in request body"; flow:established,to_server; http.request_body; pcre:"/(?:\{\{|\$\{).{0,100}(?:7\*7|__class__|__globals__|getRuntime|Runtime|process|config|request|self)/i"; classtype:web-application-attack; metadata:owasp_top_10 A05_2025, confidence High; sid:9901035; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A05:2025 XML external entity injection"; flow:established,to_server; http.request_body; content:"<!"; pcre:"/<!DOCTYPE\s+[^>]{0,300}\[\s*<!ENTITY\s+[^>]+(?:SYSTEM|PUBLIC)\s+[\x22'](?:file|https?|ftp):/is"; classtype:web-application-attack; metadata:owasp_top_10 A05_2025, confidence High; sid:9901036; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A05:2025 NoSQL operator injection in request body"; flow:established,to_server; http.request_body; pcre:"/[\x22']?\$(?:ne|gt|gte|lt|lte|regex|where|expr|function)[\x22']?\s*(?::|=)/i"; classtype:web-application-attack; metadata:owasp_top_10 A05_2025, confidence High; sid:9901037; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A05:2025 LDAP filter injection"; flow:established,to_server; http.uri.raw; pcre:"/(?:\)(?:\||&|!)\(|%29(?:%7c|%26|%21)%28).{0,100}(?:\*|%2a)/i"; classtype:web-application-attack; metadata:owasp_top_10 A05_2025, confidence Medium; sid:9901038; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A05:2025 CRLF response-splitting injection in URI"; flow:established,to_server; http.uri.raw; pcre:"/(?:%0d%0a|%0a%0d|%250d%250a|%0d%250a|%250d%0a)/i"; classtype:web-application-attack; metadata:owasp_top_10 A05_2025, confidence High; sid:9901039; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A05:2025 Log4Shell JNDI or expression injection in header"; flow:established,to_server; http.request_header; content:"${"; pcre:"/\$\{(?:jndi|lower|upper|env|sys)\s*:/i"; classtype:web-application-attack; metadata:owasp_top_10 A05_2025, confidence High; sid:9901040; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A05:2025 XPath style boolean injection in request body"; flow:established,to_server; http.request_body; pcre:"/(?:'|\x22)\s*(?:or|and)\s*(?:'[^']*'|\x22[^\x22]*\x22|[0-9]+)\s*=\s*(?:'[^']*'|\x22[^\x22]*\x22|[0-9]+)/i"; classtype:web-application-attack; metadata:owasp_top_10 A05_2025, confidence Medium; sid:9901041; rev:1;)

# =============================================================================
# A06:2025 - Insecure Design
# =============================================================================
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A06:2025 Executable server-side file upload"; flow:established,to_server; http.method; pcre:"/^(?:POST|PUT)$/"; http.content_type; content:"multipart/form-data"; nocase; file.name; pcre:"/\.(?:php[0-9]?|phtml|phar|jsp|jspx|asp|aspx|ashx|cgi|pl|py|sh|war)(?:[. ]|$)/i"; classtype:web-application-attack; metadata:owasp_top_10 A06_2025, confidence High; sid:9901042; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A06:2025 Sensitive privilege field mass assignment"; flow:established,to_server; http.method; pcre:"/^(?:POST|PUT|PATCH)$/"; http.request_body; pcre:"/[\x22']?(?:is_?admin|admin|role|roles|permissions?|privileges?)[\x22']?\s*(?::|=)\s*(?:[\x22']?(?:admin|root|superuser)[\x22']?|true|1)/i"; classtype:web-application-attack; metadata:owasp_top_10 A06_2025, confidence Medium; sid:9901043; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A06:2025 GraphQL introspection against protected application"; flow:established,to_server; http.uri; pcre:"/\/graphql(?:\/|[?]|$)/i"; http.request_body; pcre:"/\b__(?:schema|type)\b/"; classtype:attempted-recon; metadata:owasp_top_10 A06_2025, confidence Medium; sid:9901044; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A06:2025 High-rate sensitive business action automation"; flow:established,to_server; http.method; content:"POST"; http.uri; pcre:"/\/(?:checkout|transfer|payments?|coupon|redeem|reset-password|forgot-password|otp|verify)(?:\/|[?]|$)/i"; detection_filter:track by_src,count 20,seconds 60; classtype:web-application-attack; metadata:owasp_top_10 A06_2025, confidence Low; sid:9901045; rev:1;)

# =============================================================================
# A07:2025 - Authentication Failures
# =============================================================================
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A07:2025 Repeated login attempts possible brute force"; flow:established,to_server; http.method; content:"POST"; http.uri; pcre:"/\/(?:login|signin|sign-in|authenticate|session|token)(?:\/|[?]|$)/i"; detection_filter:track by_src,count 10,seconds 60; classtype:attempted-user; metadata:owasp_top_10 A07_2025, confidence Medium; sid:9901046; rev:1;)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"OWASP A07:2025 Repeated HTTP authentication failures"; flow:established,to_client; http.stat_code; pcre:"/^(?:401|403)$/"; detection_filter:track by_dst,count 10,seconds 60; classtype:attempted-user; metadata:owasp_top_10 A07_2025, confidence Medium; sid:9901047; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A07:2025 Common default credential in Basic Authorization"; flow:established,to_server; http.request_header; pcre:"/(?:^|\r\n)Authorization\s*:\s*Basic\s+(?:YWRtaW46YWRtaW4=|YWRtaW46cGFzc3dvcmQ=|cm9vdDpyb290|dGVzdDp0ZXN0)(?:\r\n|$)/i"; classtype:attempted-admin; metadata:owasp_top_10 A07_2025, confidence High; sid:9901048; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A07:2025 JWT using none algorithm"; flow:established,to_server; http.request_header; content:"eyJhbGciOiJub25lI"; nocase; classtype:web-application-attack; metadata:owasp_top_10 A07_2025, confidence High; sid:9901049; rev:1;)

# =============================================================================
# A08:2025 - Software or Data Integrity Failures
# =============================================================================
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A08:2025 Java serialized object Base64 in request body"; flow:established,to_server; http.request_body; content:"rO0AB"; classtype:web-application-attack; metadata:owasp_top_10 A08_2025, confidence High; sid:9901050; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A08:2025 Raw Java serialized object in request body"; flow:established,to_server; http.request_body; content:"|ac ed 00 05|"; classtype:web-application-attack; metadata:owasp_top_10 A08_2025, confidence High; sid:9901051; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A08:2025 PHP object deserialization payload"; flow:established,to_server; http.request_body; pcre:"/(?:^|[&=])O:[0-9]+:[\x22'][^\x22']+[\x22']:[0-9]+:\{/"; classtype:web-application-attack; metadata:owasp_top_10 A08_2025, confidence High; sid:9901052; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A08:2025 Unsafe YAML object type deserialization"; flow:established,to_server; http.request_body; pcre:"/!!(?:python\/object|python\/object\/apply|javax\.script|ruby\/object|java\/object)/i"; classtype:web-application-attack; metadata:owasp_top_10 A08_2025, confidence High; sid:9901053; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A08:2025 JavaScript prototype pollution payload"; flow:established,to_server; http.request_body; pcre:"/[\x22'](?:__proto__|constructor|prototype)[\x22']\s*(?::|=)/i"; classtype:web-application-attack; metadata:owasp_top_10 A08_2025, confidence High; sid:9901054; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A08:2025 Unsigned generic webhook request"; flow:established,to_server; http.method; content:"POST"; http.uri; pcre:"/\/(?:webhooks?|callbacks?|hooks)(?:\/|[?]|$)/i"; http.header_names; content:!"|0d 0a|X-Hub-Signature|0d 0a|"; nocase; content:!"|0d 0a|X-Hub-Signature-256|0d 0a|"; nocase; content:!"|0d 0a|Stripe-Signature|0d 0a|"; nocase; content:!"|0d 0a|X-Signature|0d 0a|"; nocase; classtype:policy-violation; metadata:owasp_top_10 A08_2025, confidence Low; sid:9901055; rev:1;)

# =============================================================================
# A09:2025 - Security Logging and Alerting Failures
# These rules detect logging evasion/tampering indicators. Absence of logging itself requires host/SIEM validation.
# =============================================================================
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A09:2025 Encoded control characters in log-relevant header"; flow:established,to_server; http.request_header; pcre:"/(?:User-Agent|Referer|X-Forwarded-For)\s*:[^\r\n]*(?:%0d%0a|%0a%0d|%00|\\r\\n)/i"; classtype:web-application-attack; metadata:owasp_top_10 A09_2025, confidence High; sid:9901056; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A09:2025 Null-byte request URI evasion"; flow:established,to_server; http.uri.raw; pcre:"/(?:%00|%2500|\\x00)/i"; classtype:web-application-attack; metadata:owasp_top_10 A09_2025, confidence High; sid:9901057; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A09:2025 Excessive percent-encoding request evasion"; flow:established,to_server; http.uri.raw; pcre:"/(?:%[0-9a-f]{2}){8,}/i"; classtype:web-application-attack; metadata:owasp_top_10 A09_2025, confidence Medium; sid:9901058; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A09:2025 High-rate requests without User-Agent telemetry"; flow:established,to_server; http.header_names; content:!"|0d 0a|User-Agent|0d 0a|"; nocase; detection_filter:track by_src,count 30,seconds 60; classtype:attempted-recon; metadata:owasp_top_10 A09_2025, confidence Low; sid:9901059; rev:1;)

# =============================================================================
# A10:2025 - Mishandling of Exceptional Conditions
# =============================================================================
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A10:2025 HTTP request smuggling Content-Length plus Transfer-Encoding"; flow:established,to_server; http.request_header; pcre:"/^(?=[\s\S]*(?:^|\r\n)Content-Length\s*:)(?=[\s\S]*(?:^|\r\n)Transfer-Encoding\s*:\s*chunked)/im"; classtype:protocol-command-decode; metadata:owasp_top_10 A10_2025, confidence High; sid:9901060; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A10:2025 Duplicate Content-Length request smuggling"; flow:established,to_server; http.request_header; pcre:"/(?:^|\r\n)Content-Length\s*:[^\r\n]*\r\n(?:[^\r\n]*\r\n)*Content-Length\s*:/i"; classtype:protocol-command-decode; metadata:owasp_top_10 A10_2025, confidence High; sid:9901061; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A10:2025 Duplicate Host header ambiguity"; flow:established,to_server; http.request_header; pcre:"/(?:^|\r\n)Host\s*:[^\r\n]*\r\n(?:[^\r\n]*\r\n)*Host\s*:/i"; classtype:protocol-command-decode; metadata:owasp_top_10 A10_2025, confidence High; sid:9901062; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A10:2025 Abnormally long request URI"; flow:established,to_server; urilen:>4096; classtype:attempted-dos; metadata:owasp_top_10 A10_2025, confidence Medium; sid:9901063; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A10:2025 Excessive declared HTTP request body size"; flow:established,to_server; http.content_len; byte_test:0,>,10485760,0,string,dec; classtype:attempted-dos; metadata:owasp_top_10 A10_2025, confidence Medium; sid:9901064; rev:1;)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"OWASP A10:2025 Repeated server errors to one client"; flow:established,to_client; http.stat_code; pcre:"/^5[0-9]{2}$/"; detection_filter:track by_dst,count 20,seconds 60; classtype:attempted-dos; metadata:owasp_top_10 A10_2025, confidence Low; sid:9901065; rev:1;)
alert http any any -> any any (msg:"OWASP A10:2025 HTTP gzip decompression failure"; app-layer-event:http.gzip_decompression_failed; classtype:protocol-command-decode; metadata:owasp_top_10 A10_2025, confidence Medium; sid:9901066; rev:1;)
